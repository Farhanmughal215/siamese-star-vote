# =============================================================================
# Siamese Star Vote — Environment template
# =============================================================================
# Copy this file to `.env.local` and fill in your Supabase project values.
# `.env.local` is git-ignored by Next.js by default.
#
# Get these from: Supabase Dashboard → Project Settings → API
# =============================================================================

# Your project's REST API URL.
# Example: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "anon" (publishable) key. Safe to expose to the browser — Row Level
# Security is what protects user data, not key secrecy.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
