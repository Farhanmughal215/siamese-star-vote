# =============================================================================
# Siamese Star Vote — Environment template
# =============================================================================
# Copy this file to `.env.local` and fill in your Supabase project values.
# `.env.local` is git-ignored by Next.js by default.
#
# Get these from: Supabase Dashboard → Project Settings → API
# =============================================================================

# Your project's REST API URL.
# Example: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "anon" (publishable) key. Safe to expose to the browser — Row Level
# Security is what protects user data, not key secrecy.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service-role key. NEVER expose to the browser. Used by admin
# actions and signup to bypass RLS where appropriate.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key — powers the "Chat with the cat" AI feature.
# Optional: when missing the chat shows a friendly placeholder instead of
# breaking. Get one at https://console.anthropic.com (free $5 credit).
ANTHROPIC_API_KEY=
